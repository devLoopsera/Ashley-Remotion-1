{
  "durationFrames": 70,
  "fps": 30,
  "width": 1920,
  "height": 1080,
  "background": {
    "type": "solid",
    "color": "#FFFFFF"
  },
  "elements": [
    {
      "id": "logo-group",
      "type": "group",
      "position": {
        "topPercent": 30,
        "centerHorizontal": true
      },
      "children": [
        {
          "id": "logo-icon",
          "type": "svg-component",
          "size": {
            "height": 156
          },
          "component": "AshleyHouseIcon",
          "props": {
            "color": "#E87722",
            "height": 156
          }
        },
        {
          "id": "logo-wordmark",
          "type": "svg-component",
          "size": {
            "height": 110
          },
          "component": "AshleyWordmark",
          "props": {
            "color": "#333333",
            "height": 110
          }
        }
      ],
      "layout": {
        "direction": "row",
        "gap": 20,
        "alignItems": "center"
      }
    },
    {
      "id": "locations",
      "type": "group",
      "isArrayProp": true,
      "propName": "locations",
      "position": {
        "belowElement": "logo-group",
        "marginTop": 40,
        "centerHorizontal": true
      },
      "layout": {
        "direction": "row",
        "gap": 60,
        "alignItems": "flex-start"
      },
      "itemTemplate": {
        "children": [
          {
            "id": "address",
            "type": "text",
            "propPath": "address",
            "style": {
              "fontFamily": "Chesna Grotesk",
              "fontSize": 64,
              "fontWeight": 600,
              "color": "#333333",
              "letterSpacing": 1,
              "textAlign": "left",
              "lineHeight": 1.1
            }
          },
          {
            "id": "city",
            "type": "text",
            "propPath": "city",
            "style": {
              "fontFamily": "Chesna Grotesk",
              "fontSize": 64,
              "fontWeight": 600,
              "color": "#333333",
              "letterSpacing": 1,
              "textAlign": "left",
              "lineHeight": 1.1
            }
          },
          {
            "id": "phone",
            "type": "text",
            "propPath": "phone",
            "style": {
              "fontFamily": "Chesna Grotesk",
              "fontSize": 64,
              "fontWeight": 600,
              "color": "#333333",
              "letterSpacing": 1,
              "textAlign": "left",
              "lineHeight": 1.1
            }
          }
        ]
      }
    }
  ],
  "animations": [
    {
      "targets": [
        "logo-group"
      ],
      "type": "fade-in",
      "startFrame": 3,
      "postEffect": "scale-throb"
    },
    {
      "targets": [
        "locations"
      ],
      "type": "slide-up",
      "startFrame": 9,
      "postEffect": null
    }
  ],
  "textContent": {
    "locations": [
      {
        "address": "Street Address",
        "city": "City, State Zip",
        "phone": "(000) 000-0000"
      }
    ],
    "tagline": null,
    "disclaimer": null
  },
  "notes": "The location information is presented as a single, left-aligned block that is centered horizontally. A custom 'phone' propPath was added to the locations itemTemplate to accommodate the visible phone number."
}