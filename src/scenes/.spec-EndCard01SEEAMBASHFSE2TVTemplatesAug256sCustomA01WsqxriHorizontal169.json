{
  "durationFrames": 70,
  "fps": 30,
  "width": 1920,
  "height": 1080,
  "background": {
    "type": "solid",
    "color": "#F3F3F3"
  },
  "elements": [
    {
      "id": "logo-group",
      "type": "group",
      "position": {
        "topPercent": 27,
        "centerHorizontal": true
      },
      "children": [
        {
          "id": "logo-icon",
          "type": "svg-component",
          "component": "AshleyHouseIcon",
          "props": {
            "color": "#E87722",
            "height": 135
          }
        },
        {
          "id": "logo-wordmark",
          "type": "svg-component",
          "component": "AshleyWordmark",
          "props": {
            "color": "#333333",
            "height": 115
          }
        }
      ],
      "layout": {
        "direction": "column",
        "gap": 25,
        "alignItems": "center"
      }
    },
    {
      "id": "locations",
      "type": "group",
      "isArrayProp": true,
      "propName": "locations",
      "position": {
        "belowElement": "logo-group",
        "marginTop": 45,
        "centerHorizontal": true
      },
      "layout": {
        "direction": "row",
        "gap": 60,
        "alignItems": "flex-start"
      },
      "itemTemplate": {
        "type": "group",
        "layout": {
          "direction": "column",
          "gap": 10,
          "alignItems": "center"
        },
        "children": [
          {
            "id": "address",
            "type": "text",
            "propPath": "address",
            "style": {
              "fontFamily": "Chesna Grotesk",
              "fontSize": 68,
              "fontWeight": 600,
              "color": "#333333",
              "textAlign": "center"
            }
          },
          {
            "id": "city",
            "type": "text",
            "propPath": "city",
            "style": {
              "fontFamily": "Chesna Grotesk",
              "fontSize": 68,
              "fontWeight": 600,
              "color": "#333333",
              "textAlign": "center",
              "lineHeight": 1.2
            }
          }
        ]
      }
    }
  ],
  "animations": [
    {
      "targets": [
        "logo-group"
      ],
      "type": "fade-in",
      "startFrame": 3,
      "postEffect": null
    },
    {
      "targets": [
        "locations"
      ],
      "type": "fade-in",
      "startFrame": 9,
      "postEffect": null
    }
  ],
  "textContent": {
    "tagline": null,
    "disclaimer": null,
    "locations": [
      {
        "address": "Street Address",
        "city": "City, State Zip\n(000) 000-0000"
      }
    ]
  },
  "notes": "The location information is presented as three lines. To comply with the mandated 'address' and 'city' propPaths, the last two lines ('City, State Zip' and the phone number) are combined into the 'city' prop with a newline character."
}