{
  "durationFrames": 44,
  "fps": 30,
  "width": 1920,
  "height": 1080,
  "background": {
    "type": "solid",
    "color": "#3A2A1E"
  },
  "elements": [
    {
      "id": "logo-group",
      "type": "group",
      "position": {
        "topPercent": 30,
        "centerHorizontal": true
      },
      "children": [
        {
          "id": "logo-icon",
          "type": "svg-component",
          "component": "AshleyHouseIcon",
          "props": {
            "color": "#FFFFFF",
            "height": 110
          }
        },
        {
          "id": "logo-wordmark",
          "type": "svg-component",
          "component": "AshleyWordmark",
          "props": {
            "color": "#FFFFFF",
            "height": 100
          }
        }
      ],
      "layout": {
        "direction": "row",
        "gap": 25,
        "alignItems": "center"
      }
    },
    {
      "id": "tagline",
      "type": "text",
      "content": "SHOP MORE DEALS IN STORE",
      "isTextProp": true,
      "propName": "tagline",
      "style": {
        "fontFamily": "Chesna Grotesk",
        "fontSize": 28,
        "fontWeight": 400,
        "color": "#FFFFFF",
        "letterSpacing": 2,
        "textTransform": "uppercase",
        "textAlign": "center"
      },
      "position": {
        "belowElement": "logo-group",
        "marginTop": 20,
        "centerHorizontal": true
      }
    },
    {
      "id": "locations",
      "type": "group",
      "isArrayProp": true,
      "propName": "locations",
      "position": {
        "bottomPx": 250,
        "centerHorizontal": true
      },
      "layout": {
        "direction": "row",
        "gap": 190,
        "alignItems": "flex-start"
      },
      "itemTemplate": {
        "layout": {
          "direction": "column",
          "gap": 5,
          "alignItems": "flex-start"
        },
        "children": [
          {
            "id": "city",
            "type": "text",
            "propPath": "city",
            "style": {
              "fontFamily": "Chesna Grotesk",
              "fontSize": 54,
              "fontWeight": 600,
              "color": "#FFFFFF",
              "letterSpacing": 1,
              "textTransform": "uppercase"
            }
          },
          {
            "id": "address",
            "type": "text",
            "propPath": "address",
            "style": {
              "fontFamily": "Chesna Grotesk",
              "fontSize": 42,
              "fontWeight": 400,
              "color": "#FFFFFF",
              "letterSpacing": 0.5
            }
          }
        ]
      }
    },
    {
      "id": "disclaimer",
      "type": "text",
      "content": null,
      "isTextProp": true,
      "propName": "disclaimer",
      "position": {
        "bottomPx": 80,
        "centerHorizontal": true
      },
      "style": {
        "fontFamily": "Chesna Grotesk",
        "fontSize": 20,
        "fontWeight": 400,
        "color": "#FFFFFF",
        "letterSpacing": 0.5,
        "textAlign": "center"
      }
    }
  ],
  "animations": [
    {
      "targets": [
        "locations"
      ],
      "type": "fade-in",
      "startFrame": 12,
      "postEffect": null
    },
    {
      "targets": [
        "logo-group",
        "tagline",
        "disclaimer"
      ],
      "type": "fade-in",
      "startFrame": 15,
      "postEffect": null
    }
  ],
  "textContent": {
    "tagline": "SHOP MORE DEALS IN STORE",
    "disclaimer": "Ashley stores are independently owned and operated. ©2026 Roger's Furniture, DBA Ashley. All rights reserved. Expiration date 3/30/2026",
    "locations": [
      {
        "city": "MARQUETTE",
        "address": "2152 US Hwy 41 W"
      },
      {
        "city": "ESCANABA",
        "address": "2222 North Lincoln Road"
      }
    ]
  },
  "notes": "The disclaimer appears to have a line break before 'Expiration date' but is treated as a single line here."
}